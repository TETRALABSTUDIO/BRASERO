# ===== Brasero backend config =====
# Copy this file to ".env" and fill in your values.

# Port the backend listens on
PORT=4242

# Public URL of your FRONTEND site (no trailing slash).
# Used for Stripe success/cancel redirects and CORS.
# Local dev example: http://localhost:8080
SITE_URL=http://localhost:8080

# Set to 1 to also serve the static HTML from this backend (single deploy).
SERVE_STATIC=0

# ----- Stripe -----
# From https://dashboard.stripe.com/test/apikeys (use test keys first)
STRIPE_SECRET_KEY=sk_test_xxx
# OPTIONAL: use an existing Stripe Price (e.g. your 1€ test product) for every checkout.
# Find it in Dashboard → Products → your product → "price_..." . Leave empty for dynamic pricing.
STRIPE_PRICE_ID=
# From the webhook you create (see LAUNCH.md). Optional for local tests (the success redirect works without it).
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ----- Supabase (orders DB) -----
# Project Settings → API. Use the SERVICE ROLE key (server-side only, secret!).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ----- Email (optional) -----
# Leave SMTP_HOST empty to just log emails to the console (good for dev).
# Works with any SMTP provider (Gmail, Mailgun, Brevo, Postmark, etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Brasero <hello@brasero.studio>"
MAIL_TO=you@brasero.studio
